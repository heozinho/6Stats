{
  "name": "6Stats",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "deploy:backend": "wrangler deploy --minify",
    "deploy:frontend": "cd frontend && npm run build && npx wrangler pages deploy dist --project-name 6stats",
    "deploy:all": "npm run db:push && npm run deploy:backend && npm run deploy:frontend",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@upstash/redis": "^1.37.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "wrangler": "^4.4.0"
  }
}
