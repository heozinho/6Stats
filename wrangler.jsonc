{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "6stats",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "r2_buckets": [
    {
      "binding": "ARCHIVE_BUCKET",
      "bucket_name": "music-stats-archive"
    }
  ],
  "triggers": {
    "crons": [
      "0 0 * * *",
      "0 2 * * 0"
    ]
  }
}